---
const TOPIC_LABELS: Record<string, string> = {
  'ai-security': 'AI Security',
  'agentic-ai-security': 'Agentic AI Security',
  'development-playbooks': 'Development Playbooks',
  'compliance-risk': 'Compliance & Risk',
};

export interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  topic: string;
  status: string;
  version?: string;
}
const { href, title, description, pubDate, topic, status, version } = Astro.props;
const dateStr = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' }).toUpperCase();
const topicLabel = TOPIC_LABELS[topic] ?? topic;
const statusLabel = status === 'working-paper' ? 'Working Paper' : status === 'draft' ? 'Draft' : null;
---
<article class="py-7">
  <a href={href} class="block group">
    <div class="flex flex-wrap items-baseline gap-x-3 font-mono text-[11px] tracking-wider uppercase text-cream-800 dark:text-cream-300 mb-2.5">
      <time>{dateStr}</time>
      <span class="text-rust-500">/ {topicLabel}</span>
      {statusLabel && <span class="opacity-60">· {statusLabel}</span>}
      {version && <span class="opacity-60">· {version}</span>}
    </div>
    <h2 class="font-serif text-2xl sm:text-[1.75rem] font-semibold tracking-tight group-hover:text-rust-500 transition-colors leading-tight mb-3" style="font-variation-settings: 'opsz' 60, 'SOFT' 50;">
      {title}
    </h2>
    <p class="text-cream-800 dark:text-cream-200 leading-relaxed">{description}</p>
  </a>
</article>
