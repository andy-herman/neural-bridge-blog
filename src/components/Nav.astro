---
export interface Props {
  wide?: boolean;
}
const { wide = false } = Astro.props;
const widthClass = wide ? 'max-w-6xl' : 'max-w-3xl';

const links = [
  { href: '/', label: 'Home' },
  { href: '/posts', label: 'Posts' },
  { href: '/research', label: 'Research' },
  { href: '/projects', label: 'Projects' },
  { href: '/buildlog', label: 'Build log' },
  { href: '/agents', label: 'Agents' },
  { href: '/about', label: 'About' },
];
---
<header class="border-b border-cream-200 dark:border-cream-900 relative">
  <div class={`${widthClass} mx-auto px-6 py-5 flex items-center justify-between gap-3`}>
    <a href="/" class="flex items-center gap-2.5 font-serif text-lg font-semibold tracking-tight shrink-0" style="font-variation-settings: 'opsz' 36, 'SOFT' 30;">
      <svg viewBox="0 0 100 100" class="w-6 h-6 shrink-0" aria-hidden="true">
        <path d="M 28 62 A 22 22 0 0 1 72 62" fill="none" stroke="#c2410c" stroke-width="7" stroke-linecap="round"/>
        <circle cx="28" cy="62" r="9" fill="#c2410c"/>
        <circle cx="72" cy="62" r="9" fill="#c2410c"/>
      </svg>
      <span class="whitespace-nowrap">neural-<span class="text-rust-500">bridge</span>.dev</span>
    </a>

    <div class="flex items-center gap-3">
      <nav class="hidden md:block">
        <ul class="flex gap-x-4 text-sm">
          {links.map(({ href, label }, i) => (
            <li>
              <a href={href} class="text-cream-800 hover:text-cream-950 dark:text-cream-200 dark:hover:text-cream-50 transition-colors whitespace-nowrap">
                <span class="nav-num">{String(i + 1).padStart(2, '0')}</span>{label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <a
        href="https://buymeacoffee.com/neuralbridge"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-rust-500 hover:bg-rust-600 text-cream-50 text-xs font-medium rounded transition-colors whitespace-nowrap shrink-0"
      >
        <span aria-hidden="true">☕</span>
        <span class="hidden xs:inline sm:inline">Support</span>
      </a>

      <button
        id="mobile-menu-toggle"
        class="md:hidden p-1 -mr-1 text-cream-800 dark:text-cream-200"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden border-t border-cream-200 dark:border-cream-900 bg-cream-100 dark:bg-cream-950">
    <ul class={`${widthClass} mx-auto px-6 py-4 space-y-3 text-sm`}>
      {links.map(({ href, label }, i) => (
        <li>
          <a href={href} class="block text-cream-800 hover:text-cream-950 dark:text-cream-200 dark:hover:text-cream-50 transition-colors">
            <span class="nav-num">{String(i + 1).padStart(2, '0')}</span>{label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isHidden));
  });
</script>
