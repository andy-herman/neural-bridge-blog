---
// Buttondown form embed.
// 1. Sign up at https://buttondown.email/
// 2. Get your form URL at https://buttondown.email/settings/embeds
// 3. Set BUTTONDOWN_FORM in .env, or replace the YOUR_USERNAME placeholder.
const formAction = import.meta.env.BUTTONDOWN_FORM
  || 'https://buttondown.email/api/emails/embed-subscribe/YOUR_USERNAME';
---
<aside class="my-14 py-8 border-y border-cream-200 dark:border-cream-900">
  <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-3">// Subscribe</p>
  <h3 class="font-serif text-2xl font-semibold mb-2 tracking-tight" style="font-variation-settings: 'opsz' 60, 'SOFT' 50;">
    Build-in-public, in your inbox.
  </h3>
  <p class="text-sm text-cream-800 dark:text-cream-200 mb-5 max-w-md">
    New posts on Neural Bridge and whatever else I'm building. No automation, no newsletter-bot voice. Unsubscribe whenever.
  </p>
  <form action={formAction} method="post" target="popupwindow" class="flex flex-col sm:flex-row gap-2 max-w-md">
    <input
      type="email"
      name="email"
      required
      placeholder="you@domain.com"
      class="flex-1 px-3 py-2.5 border border-cream-300 dark:border-cream-800 rounded bg-cream-50 dark:bg-cream-900 text-sm font-mono placeholder:text-cream-300 focus:outline-none focus:border-rust-500 transition-colors"
    />
    <button
      type="submit"
      class="px-5 py-2.5 bg-rust-500 text-cream-50 text-sm font-medium rounded hover:bg-rust-600 transition-colors"
    >
      Subscribe
    </button>
  </form>
  <p class="font-mono text-[11px] text-cream-800 dark:text-cream-300 mt-3 opacity-70">
    Powered by <a href="https://buttondown.email" class="underline hover:text-rust-500">Buttondown</a>
  </p>
</aside>
