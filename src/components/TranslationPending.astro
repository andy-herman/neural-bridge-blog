---
// Shown on a /ko/* page whose underlying content hasn't been translated
// into Korean yet. Renders a friendly dashed-border placeholder + a link
// back to the English version so the reader has a path forward.

import { t, type Locale } from '../lib/i18n';

export interface Props {
  locale: Locale;
  englishHref: string;
  englishTitle?: string;
}
const { locale, englishHref, englishTitle } = Astro.props;
const s = t(locale);
---
<div class="border border-dashed border-cream-300 dark:border-cream-800 rounded p-8 text-center">
  <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-3">// {s.translation_pending.title}</p>
  <p class="font-serif italic text-cream-800 dark:text-cream-200 mb-5 max-w-xl mx-auto leading-relaxed">
    {s.translation_pending.body}
  </p>
  <a
    href={englishHref}
    class="inline-block font-mono text-xs uppercase tracking-wider px-3 py-1.5 rounded-full border border-cream-300 dark:border-cream-700 text-cream-800 dark:text-cream-200 hover:border-rust-500 hover:text-rust-600 dark:hover:text-rust-400 transition-colors"
  >
    {s.translation_pending.cta}{englishTitle ? ` (${englishTitle})` : ''} &rarr;
  </a>
</div>
