---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../components/BaseLayout.astro';
import fs from 'node:fs/promises';
import path from 'node:path';
import { t } from '../../../lib/i18n';

const locale = 'ko';
const s = t(locale);

// Try to use Korean agent entries where they exist; fall back to English.
// In PR A there are no Korean agent entries yet — all fall back. The
// translation-pending badge marks which ones are awaiting translation.
const enAgents = (await getCollection('agents', ({ id }) => !id.startsWith('ko/')))
  .sort((a, b) => a.data.display_name.localeCompare(b.data.display_name));

const koAgents = await getCollection('agents', ({ id }) => id.startsWith('ko/'));
const koAgentMap = new Map(koAgents.map(a => [a.data.id, a]));

const COLOR_HEX: Record<string, string> = {
  red: '#dc2626', orange: '#ea580c', yellow: '#ca8a04', green: '#16a34a',
  blue: '#2563eb', purple: '#9333ea', cyan: '#0891b2', pink: '#db2777',
  white: '#a8a29e', magenta: '#c026d3',
};

const publicAgentsDir = path.resolve('./public/agents');
let availableAvatars: Set<string>;
try {
  const files = await fs.readdir(publicAgentsDir);
  availableAvatars = new Set(files.filter(f => f.endsWith('.png')).map(f => f.replace(/\.png$/, '')));
} catch {
  availableAvatars = new Set();
}
---
<BaseLayout title="에이전트 · neural-bridge.dev" wide locale={locale}>
  <header class="mb-12 pt-4">
    <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-3">{s.pages.agents_kicker}</p>
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight mb-4" style="font-variation-settings: 'opsz' 96, 'SOFT' 60;">{s.pages.agents_title}</h1>
    <p class="font-serif italic text-lg text-cream-800 dark:text-cream-200 max-w-2xl">
      {s.pages.agents_blurb}
    </p>
  </header>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
    {enAgents.map(enAgent => {
      const ko = koAgentMap.get(enAgent.data.id);
      const display = ko ?? enAgent;
      const translated = !!ko;
      const accent = COLOR_HEX[enAgent.data.color] || '#a8a29e';
      const hasAvatar = availableAvatars.has(enAgent.data.id);
      return (
        <a
          href={`/ko/agents/${enAgent.data.id}`}
          class="group block border border-cream-200 dark:border-cream-900 rounded-lg overflow-hidden hover:border-rust-500 transition-colors bg-cream-50 dark:bg-cream-950"
        >
          <div class="h-1.5" style={`background-color: ${accent};`} aria-hidden="true"></div>
          <div class="p-5">
            <div class="aspect-square rounded-md overflow-hidden mb-4 bg-cream-100 dark:bg-cream-900 flex items-center justify-center">
              {hasAvatar ? (
                <img src={`/agents/${enAgent.data.id}.png`} alt={display.data.display_name} width="512" height="512" loading="lazy" class="w-full h-full object-cover" />
              ) : (
                <div class="flex flex-col items-center justify-center text-center p-4">
                  <p class="font-mono text-[10px] uppercase tracking-wider text-cream-600 dark:text-cream-400 mb-1">{s.agent_detail.no_avatar}</p>
                  <p class="font-serif text-xl font-semibold text-cream-700 dark:text-cream-300">{display.data.display_name}</p>
                </div>
              )}
            </div>
            <div class="flex items-baseline gap-x-2 mb-1.5">
              <span class="font-mono text-[11px] uppercase tracking-wider" style={`color: ${accent};`}>// {enAgent.data.color}</span>
              {enAgent.data.is_orchestrator && (
                <span class="font-mono text-[11px] uppercase tracking-wider text-rust-500">{s.agent_detail.orchestrator_badge}</span>
              )}
              {!translated && (
                <span class="font-mono text-[10px] uppercase tracking-wider text-cream-500 dark:text-cream-600">· 번역 준비 중</span>
              )}
            </div>
            <h2 class="font-serif text-xl font-semibold tracking-tight mb-2 group-hover:text-rust-500 transition-colors leading-tight" style="font-variation-settings: 'opsz' 60, 'SOFT' 50;">
              {display.data.display_name}
            </h2>
            <p class="font-serif italic text-sm text-cream-700 dark:text-cream-300 leading-snug mb-3">
              {display.data.role_tagline}
            </p>
            <p class="font-mono text-[10px] uppercase tracking-wider text-cream-600 dark:text-cream-400 group-hover:text-rust-500 transition-colors">
              프로필 보기 &rarr;
            </p>
          </div>
        </a>
      );
    })}
  </div>
</BaseLayout>
