---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../components/BaseLayout.astro';
import { t, localePath } from '../../../lib/i18n';

const locale = 'ko';
const s = t(locale);

const RECENT_PER_SECTION = 3;

// All collections — count both EN and KO entries for the totals, but only
// display KO entries if they exist, else fall back to EN with a flag.

function localizeSlug(id: string): string {
  return id.replace(/^ko\//, '');
}

interface DisplayItem {
  href: string;
  title: string;
  description: string;
  date: Date;
  meta?: string;
  translated: boolean;
}

async function getMergedCollection(name: 'posts' | 'research' | 'projects'): Promise<{ items: DisplayItem[]; total: number }> {
  const en = await getCollection(name, (e: any) => !e.data.draft && !e.id.startsWith('ko/'));
  const ko = await getCollection(name, (e: any) => e.id.startsWith('ko/'));
  const koSlugs = new Set(ko.map((e: any) => localizeSlug(e.id).replace(/\.mdx?$/, '')));

  const items: DisplayItem[] = [];
  for (const e of ko) {
    const slug = localizeSlug((e as any).slug);
    items.push({
      href: localePath(locale, `/${name}/${slug}`),
      title: (e as any).data.title,
      description: (e as any).data.description,
      date: name === 'projects' ? (e as any).data.started : (e as any).data.pubDate,
      translated: true,
    });
  }
  for (const e of en) {
    const slugNoExt = (e as any).slug.replace(/\.mdx?$/, '');
    if (koSlugs.has(slugNoExt)) continue;
    items.push({
      href: localePath(locale, `/${name}/${(e as any).slug}`),
      title: (e as any).data.title,
      description: (e as any).data.description,
      date: name === 'projects' ? (e as any).data.started : (e as any).data.pubDate,
      translated: false,
    });
  }
  items.sort((a, b) => b.date.valueOf() - a.date.valueOf());
  return { items, total: items.length };
}

const postsResult = await getMergedCollection('posts');
const researchResult = await getMergedCollection('research');
const projectsResult = await getMergedCollection('projects');

const recentPosts = postsResult.items.slice(0, RECENT_PER_SECTION);
const recentResearch = researchResult.items.slice(0, RECENT_PER_SECTION);
const recentProjects = projectsResult.items.slice(0, RECENT_PER_SECTION);

function dateLabel(d: Date): string {
  const y = d.getUTCFullYear();
  const m = d.getUTCMonth() + 1;
  const day = d.getUTCDate();
  return `${y}년 ${m}월 ${day}일`;
}
---
<BaseLayout title="글 · neural-bridge.dev" wide locale={locale}>
  <header class="mb-14 pt-4">
    <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-3">{s.pages.writing_kicker}</p>
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight mb-4" style="font-variation-settings: 'opsz' 96, 'SOFT' 60;">{s.pages.writing_title}</h1>
    <p class="font-serif italic text-lg text-cream-800 dark:text-cream-200 max-w-2xl" set:html={s.pages.writing_blurb_html}></p>
  </header>

  {[
    { label: '포스트', items: recentPosts, total: postsResult.total, indexHref: localePath(locale, '/posts'), kicker: s.sections.posts_kicker, tagline: s.sections.posts_tagline, allLabel: '포스트' },
    { label: '리서치', items: recentResearch, total: researchResult.total, indexHref: localePath(locale, '/research'), kicker: s.sections.research_kicker, tagline: s.sections.research_tagline, allLabel: '리서치' },
    { label: '프로젝트', items: recentProjects, total: projectsResult.total, indexHref: localePath(locale, '/projects'), kicker: s.sections.projects_kicker, tagline: s.sections.projects_tagline, allLabel: '프로젝트' },
  ].map(section => (
    section.items.length > 0 && (
      <section class="mb-14 border-t border-cream-200 dark:border-cream-900 pt-6">
        <div class="flex items-baseline justify-between mb-2 flex-wrap gap-y-1">
          <div>
            <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-1">{section.kicker}</p>
            <p class="font-serif italic text-sm text-cream-700 dark:text-cream-300">{section.tagline}</p>
          </div>
          <a href={section.indexHref} class="font-mono text-xs uppercase tracking-wider text-cream-800 dark:text-cream-300 hover:text-rust-500 transition-colors shrink-0">{section.allLabel} 전체 ({section.total}) &rarr;</a>
        </div>
        <div class="editorial-list">
          {section.items.map(item => (
            <article class="py-7">
              <a href={item.href} class="block group">
                <div class="flex flex-wrap items-baseline gap-x-3 font-mono text-[11px] tracking-wider uppercase mb-2.5">
                  <time class="text-cream-800 dark:text-cream-300">{dateLabel(item.date)}</time>
                  {!item.translated && (
                    <span class="text-cream-500 dark:text-cream-600">· 번역 준비 중</span>
                  )}
                </div>
                <h2 class="font-serif text-2xl sm:text-[1.75rem] font-semibold tracking-tight group-hover:text-rust-500 transition-colors leading-tight mb-3" style="font-variation-settings: 'opsz' 60, 'SOFT' 50;">
                  {item.title}
                </h2>
                <p class="text-cream-800 dark:text-cream-200 leading-relaxed">{item.description}</p>
              </a>
            </article>
          ))}
        </div>
      </section>
    )
  ))}
</BaseLayout>
