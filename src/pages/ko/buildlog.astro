---
// Buildlog Korean view — chrome localized, entries stay in English (auto-sync
// entries are short and high-volume; translating them all isn't worth it per
// Andy's call). Mirror of the English /buildlog page with Korean strings.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import { t } from '../../lib/i18n';

const locale = 'ko';
const s = t(locale);

const KIND_LABELS_KO: Record<string, string> = {
  milestone: '마일스톤',
  release: '릴리스',
  feature: '기능',
  post: '포스트',
  hardening: '하드닝',
  fix: '수정',
  note: '노트',
};

const KIND_COLOR: Record<string, string> = {
  milestone: 'text-rust-500',
  post: 'text-rust-600',
  release: 'text-cream-700 dark:text-cream-300',
  feature: 'text-cream-700 dark:text-cream-300',
  hardening: 'text-cream-600 dark:text-cream-400',
  fix: 'text-cream-600 dark:text-cream-400',
  note: 'text-cream-500 dark:text-cream-500',
};

const PROJECT_LABELS_KO: Record<string, string> = {
  'neural-bridge': 'neural-bridge',
  'neural-bridge-blog': 'neural-bridge-blog',
  'seoul-eland-digest': 'seoul-eland-digest',
  'cross-cutting': '공통',
};

const allEntries = (await getCollection('buildlog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestEntryId = allEntries[0]?.id;

function monthKey(d: Date): string {
  // Korean month-year: 2026년 5월
  const y = d.getUTCFullYear();
  const m = d.getUTCMonth() + 1;
  return `${y}년 ${m}월`;
}

const byMonth = allEntries.reduce<Record<string, typeof allEntries>>((acc, entry) => {
  const k = monthKey(entry.data.date);
  (acc[k] = acc[k] || []).push(entry);
  return acc;
}, {});

function dayLabel(d: Date): string {
  const m = d.getUTCMonth() + 1;
  const day = d.getUTCDate();
  return `${m}월 ${day}일`;
}
---
<BaseLayout title={`${s.pages.buildlog_title} · neural-bridge.dev`} wide locale={locale}>
  <header class="mb-12 pt-4">
    <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-3">{s.pages.buildlog_kicker}</p>
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight mb-4" style="font-variation-settings: 'opsz' 96, 'SOFT' 60;">{s.pages.buildlog_title}</h1>
    <p class="font-serif italic text-lg text-cream-800 dark:text-cream-200 max-w-2xl">
      {s.pages.buildlog_blurb}
    </p>
    <p class="font-mono text-xs text-cream-600 dark:text-cream-500 mt-3">
      참고: 빌드 로그 항목 본문은 영어 그대로 유지됩니다.
    </p>
  </header>

  {Object.entries(byMonth).map(([month, monthEntries]) => (
    <section class="mb-12">
      <p class="font-mono text-xs uppercase tracking-wider mb-4 border-t border-cream-200 dark:border-cream-900 pt-6">
        <span class="text-rust-500">{month}</span>
        <span class="text-cream-600 dark:text-cream-500"> · {monthEntries.length === 1 ? s.buildlog.one_entry : s.buildlog.n_entries(monthEntries.length)}</span>
      </p>
      <ol class="space-y-8">
        {monthEntries.map(async (entry) => {
          const { Content } = await render(entry);
          const kindColor = KIND_COLOR[entry.data.kind] || 'text-rust-500';
          const kindLabel = KIND_LABELS_KO[entry.data.kind] || entry.data.kind;
          const isLatest = entry.id === latestEntryId;
          return (
            <li class="border-l border-cream-200 dark:border-cream-900 pl-6">
              <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-1.5">
                <span class={`font-mono text-xs uppercase tracking-wider ${kindColor}`}>
                  // {kindLabel}{isLatest && (<span class="text-rust-500"> {s.buildlog.latest_badge}</span>)}
                </span>
                <time class="font-mono text-xs text-cream-700 dark:text-cream-400" datetime={entry.data.date.toISOString()}>{dayLabel(entry.data.date)}</time>
                <span class="font-mono text-xs text-cream-600 dark:text-cream-500">{PROJECT_LABELS_KO[entry.data.project] || entry.data.project}</span>
              </div>
              <h2 class="font-serif text-xl sm:text-2xl font-semibold tracking-tight mb-3">{entry.data.title}</h2>
              <div class="prose prose-cream dark:prose-invert prose-sm max-w-none mb-4">
                <Content />
              </div>
              {entry.data.links.length > 0 && (
                <ul class="flex flex-wrap gap-2">
                  {entry.data.links.map(link => (
                    <li>
                      <a
                        href={link.url}
                        class="inline-block font-mono text-xs px-2.5 py-0.5 rounded-full border border-cream-300 dark:border-cream-700 text-cream-800 dark:text-cream-200 hover:border-rust-500 hover:text-rust-600 dark:hover:text-rust-400 transition-colors"
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          );
        })}
      </ol>
    </section>
  ))}
</BaseLayout>
