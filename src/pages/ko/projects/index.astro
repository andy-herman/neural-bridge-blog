---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../components/BaseLayout.astro';
import { t } from '../../../lib/i18n';

const locale = 'ko';
const s = t(locale);

const STATUS_LABEL_KO: Record<string, string> = {
  active: '활성',
  paused: '일시정지',
  archived: '아카이브',
};

const enProjects = (await getCollection('projects', ({ id }) => !id.startsWith('ko/')))
  .sort((a, b) => b.data.started.valueOf() - a.data.started.valueOf());
const koProjects = await getCollection('projects', ({ id }) => id.startsWith('ko/'));
const koSlugMap = new Map(koProjects.map(p => [p.slug.replace(/^ko\//, ''), p]));

function dateLabel(d: Date): string {
  const y = d.getUTCFullYear();
  const m = d.getUTCMonth() + 1;
  const day = d.getUTCDate();
  return `${y}년 ${m}월 ${day}일`;
}
---
<BaseLayout title="프로젝트 · neural-bridge.dev" wide locale={locale}>
  <header class="mb-12 pt-4">
    <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-3">{s.pages.projects_kicker}</p>
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight" style="font-variation-settings: 'opsz' 96, 'SOFT' 60;">{s.pages.projects_title}</h1>
  </header>

  {enProjects.length === 0 && (<p class="font-serif italic text-cream-800 dark:text-cream-300">아직 프로젝트가 없습니다.</p>)}

  <div class="editorial-list">
    {enProjects.map(en => {
      const ko = koSlugMap.get(en.slug);
      const display = ko ?? en;
      const translated = !!ko;
      return (
        <article class="py-7">
          <a href={`/ko/projects/${en.slug}`} class="block group">
            <div class="flex items-baseline gap-3 font-mono text-[11px] tracking-wider uppercase text-cream-800 dark:text-cream-300 mb-2.5">
              <time>{dateLabel(en.data.started)}</time>
              <span class="text-rust-500">/ {STATUS_LABEL_KO[en.data.status] || en.data.status}</span>
              {!translated && (<span class="text-cream-500 dark:text-cream-600">· 번역 준비 중</span>)}
            </div>
            <h2 class="font-serif text-2xl sm:text-[1.75rem] font-semibold tracking-tight group-hover:text-rust-500 transition-colors leading-tight mb-3" style="font-variation-settings: 'opsz' 60, 'SOFT' 50;">{display.data.title}</h2>
            <p class="text-cream-800 dark:text-cream-200 leading-relaxed">{display.data.description}</p>
          </a>
        </article>
      );
    })}
  </div>
</BaseLayout>
