---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../components/BaseLayout.astro';
import TranslationPending from '../../../components/TranslationPending.astro';

const locale = 'ko';

const STATUS_LABEL_KO: Record<string, string> = {
  active: '활성',
  paused: '일시정지',
  archived: '아카이브',
};

export async function getStaticPaths() {
  const enProjects = await getCollection('projects', ({ id }) => !id.startsWith('ko/'));
  const koProjects = await getCollection('projects', ({ id }) => id.startsWith('ko/'));
  const koSlugMap = new Map(koProjects.map(p => [p.slug.replace(/^ko\//, ''), p]));
  return enProjects.map(en => ({
    params: { slug: en.slug },
    props: { enProject: en, koProject: koSlugMap.get(en.slug) ?? null },
  }));
}

const { enProject, koProject } = Astro.props;
const display = koProject ?? enProject;
const translated = !!koProject;
const { Content } = translated ? await render(koProject) : { Content: null };

function dateLabel(d: Date): string {
  const y = d.getUTCFullYear();
  const m = d.getUTCMonth() + 1;
  const day = d.getUTCDate();
  return `${y}년 ${m}월 ${day}일`;
}
---
<BaseLayout title={`${display.data.title} · neural-bridge.dev`} locale={locale}>
  <article>
    <a href="/ko/projects" class="inline-block mb-6 font-mono text-xs uppercase tracking-wider text-cream-700 dark:text-cream-300 hover:text-rust-500 transition-colors">
      &larr; 프로젝트 전체
    </a>

    <header class="mb-8">
      <div class="flex items-baseline gap-3 font-mono text-[11px] tracking-wider uppercase text-cream-800 dark:text-cream-300 mb-3">
        <time>{dateLabel(enProject.data.started)}</time>
        <span class="text-rust-500">/ {STATUS_LABEL_KO[enProject.data.status] || enProject.data.status}</span>
      </div>
      <h1 class="font-serif text-3xl sm:text-4xl font-semibold tracking-tight leading-tight mb-4" style="font-variation-settings: 'opsz' 96, 'SOFT' 60;">{display.data.title}</h1>
      <p class="font-serif italic text-lg text-cream-800 dark:text-cream-200 leading-relaxed">{display.data.description}</p>
    </header>

    {!translated && (
      <div class="mb-10">
        <TranslationPending locale={locale} englishHref={`/projects/${enProject.slug}`} englishTitle={enProject.data.title} />
      </div>
    )}

    {translated && Content && (
      <div class="prose prose-cream dark:prose-invert max-w-none">
        <Content />
      </div>
    )}
  </article>
</BaseLayout>
