---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../../components/BaseLayout.astro';
import TranslationPending from '../../../components/TranslationPending.astro';
import { t } from '../../../lib/i18n';

const locale = 'ko';
const s = t(locale);

export async function getStaticPaths() {
  const enPapers = await getCollection('research', ({ data, id }) => !data.draft && !id.startsWith('ko/'));
  const koPapers = await getCollection('research', ({ id }) => id.startsWith('ko/'));
  const koSlugMap = new Map(koPapers.map(p => [p.slug.replace(/^ko\//, ''), p]));
  return enPapers.map(en => ({
    params: { slug: en.slug },
    props: { enPaper: en, koPaper: koSlugMap.get(en.slug) ?? null },
  }));
}

const { enPaper, koPaper } = Astro.props;
const display = koPaper ?? enPaper;
const translated = !!koPaper;
const { Content } = translated ? await render(koPaper) : { Content: null };

const TOPIC_LABELS_KO: Record<string, string> = {
  'ai-security': 'AI 보안',
  'agentic-ai-security': '에이전틱 AI 보안',
  'development-playbooks': '개발 플레이북',
  'compliance-risk': '컴플라이언스와 리스크',
};
const STATUS_LABELS_KO: Record<string, string> = {
  'working-paper': '워킹 페이퍼',
  'draft': '드래프트',
  'published': '게시됨',
};

function dateLabel(d: Date): string {
  const y = d.getUTCFullYear();
  const m = d.getUTCMonth() + 1;
  const day = d.getUTCDate();
  return `${y}년 ${m}월 ${day}일`;
}
---
<BaseLayout title={`${display.data.title} · neural-bridge.dev`} locale={locale}>
  <article>
    <a href="/ko/research" class="inline-block mb-6 font-mono text-xs uppercase tracking-wider text-cream-700 dark:text-cream-300 hover:text-rust-500 transition-colors">
      &larr; 리서치 전체
    </a>

    <header class="mb-10">
      <div class="flex flex-wrap items-baseline gap-x-3 font-mono text-[11px] tracking-wider uppercase text-cream-800 dark:text-cream-300 mb-4">
        <time>{dateLabel(display.data.pubDate)}</time>
        <span class="text-rust-500">/ {TOPIC_LABELS_KO[enPaper.data.topic] || enPaper.data.topic}</span>
        {display.data.status && <span class="opacity-60">· {STATUS_LABELS_KO[display.data.status] || display.data.status}</span>}
        {display.data.version && <span class="opacity-60">· {display.data.version}</span>}
      </div>
      <h1 class="font-serif text-3xl sm:text-4xl font-semibold tracking-tight leading-tight mb-4" style="font-variation-settings: 'opsz' 96, 'SOFT' 60;">{display.data.title}</h1>
      <p class="font-serif italic text-lg text-cream-800 dark:text-cream-200 leading-relaxed">{display.data.description}</p>
    </header>

    {!translated && (
      <div class="mb-10">
        <TranslationPending locale={locale} englishHref={`/research/${enPaper.slug}`} englishTitle={enPaper.data.title} />
      </div>
    )}

    {translated && Content && (
      <div class="prose prose-cream dark:prose-invert max-w-none">
        <Content />
      </div>
    )}
  </article>
</BaseLayout>
