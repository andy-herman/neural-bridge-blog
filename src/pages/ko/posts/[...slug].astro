---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../components/BaseLayout.astro';
import TranslationPending from '../../../components/TranslationPending.astro';
import { t } from '../../../lib/i18n';

const locale = 'ko';
const s = t(locale);

export async function getStaticPaths() {
  const enPosts = await getCollection('posts', ({ data, id }) => !data.draft && !id.startsWith('ko/'));
  const koPosts = await getCollection('posts', ({ id }) => id.startsWith('ko/'));
  const koSlugMap = new Map(koPosts.map(p => [p.slug.replace(/^ko\//, ''), p]));
  return enPosts.map(en => ({
    params: { slug: en.slug },
    props: { enPost: en, koPost: koSlugMap.get(en.slug) ?? null },
  }));
}

const { enPost, koPost } = Astro.props;
const display = koPost ?? enPost;
const translated = !!koPost;
const { Content } = translated ? await render(koPost) : { Content: null };

function dateLabel(d: Date): string {
  const y = d.getUTCFullYear();
  const m = d.getUTCMonth() + 1;
  const day = d.getUTCDate();
  return `${y}년 ${m}월 ${day}일`;
}
---
<BaseLayout title={`${display.data.title} · neural-bridge.dev`} locale={locale}>
  <article>
    <a href="/ko/posts" class="inline-block mb-6 font-mono text-xs uppercase tracking-wider text-cream-700 dark:text-cream-300 hover:text-rust-500 transition-colors">
      &larr; 포스트 전체
    </a>

    <header class="mb-8">
      <div class="flex items-baseline gap-3 font-mono text-[11px] tracking-wider text-cream-800 dark:text-cream-300 mb-3">
        <time>{dateLabel(display.data.pubDate)}</time>
        {enPost.data.project && <span class="text-rust-500">/ {enPost.data.project.toUpperCase()}</span>}
      </div>
      <h1 class="font-serif text-3xl sm:text-4xl font-semibold tracking-tight leading-tight mb-4" style="font-variation-settings: 'opsz' 96, 'SOFT' 60;">{display.data.title}</h1>
      <p class="font-serif italic text-lg text-cream-800 dark:text-cream-200 leading-relaxed">{display.data.description}</p>
    </header>

    {!translated && (
      <div class="mb-10">
        <TranslationPending locale={locale} englishHref={`/posts/${enPost.slug}`} englishTitle={enPost.data.title} />
      </div>
    )}

    {translated && Content && (
      <div class="prose prose-cream dark:prose-invert max-w-none">
        <Content />
      </div>
    )}
  </article>
</BaseLayout>
