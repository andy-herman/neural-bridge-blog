---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';

const KIND_LABELS: Record<string, string> = {
  milestone: 'milestone',
  release: 'release',
  feature: 'feature',
  post: 'post',
  hardening: 'hardening',
  fix: 'fix',
  note: 'note',
};

const PROJECT_LABELS: Record<string, string> = {
  'neural-bridge': 'neural-bridge',
  'neural-bridge-blog': 'neural-bridge-blog',
  'seoul-eland-digest': 'seoul-eland-digest',
  'cross-cutting': 'cross-cutting',
};

const allEntries = (await getCollection('buildlog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by month bucket: "May 2026", etc.
function monthKey(d: Date): string {
  return d.toLocaleString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' });
}

const byMonth = allEntries.reduce<Record<string, typeof allEntries>>((acc, entry) => {
  const k = monthKey(entry.data.date);
  (acc[k] = acc[k] || []).push(entry);
  return acc;
}, {});

// Render bodies once at build time so we can stream them inline
const renderedBodies: Record<string, string> = {};
for (const entry of allEntries) {
  const { Content } = await render(entry);
  // Astro's render returns a component; we'll pass the entry through and render in template instead
  renderedBodies[entry.id] = entry.body;
}

function dayLabel(d: Date): string {
  return d.toLocaleString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
}
---
<BaseLayout title="Build log · neural-bridge.dev">
  <header class="mb-12 pt-4">
    <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-3">// Live feed</p>
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight mb-4" style="font-variation-settings: 'opsz' 96, 'SOFT' 60;">Build log</h1>
    <p class="font-serif italic text-lg text-cream-800 dark:text-cream-200 max-w-2xl">
      Chronological feed of work across my projects. Milestones, releases, hardening, posts. Hand-curated for now; auto-sync from merged PRs lands later.
    </p>
  </header>

  {allEntries.length === 0 && (
    <p class="font-serif italic text-cream-800 dark:text-cream-300">No entries yet.</p>
  )}

  {Object.entries(byMonth).map(([month, monthEntries]) => (
    <section class="mb-12">
      <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-4 border-t border-cream-200 dark:border-cream-900 pt-6">{month}</p>
      <ol class="space-y-8">
        {monthEntries.map(async (entry) => {
          const { Content } = await render(entry);
          return (
            <li class="border-l border-cream-200 dark:border-cream-900 pl-6">
              <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-2">
                <span class="font-mono text-xs text-rust-500 uppercase tracking-wider">// {KIND_LABELS[entry.data.kind] || entry.data.kind}</span>
                <time class="font-mono text-xs text-cream-700 dark:text-cream-400" datetime={entry.data.date.toISOString()}>{dayLabel(entry.data.date)}</time>
                <span class="font-mono text-xs text-cream-600 dark:text-cream-500">{PROJECT_LABELS[entry.data.project] || entry.data.project}</span>
              </div>
              <h2 class="font-serif text-xl sm:text-2xl font-semibold tracking-tight mb-3">{entry.data.title}</h2>
              <div class="prose prose-cream dark:prose-invert prose-sm max-w-none mb-3">
                <Content />
              </div>
              {entry.data.links.length > 0 && (
                <ul class="flex flex-wrap gap-3 font-mono text-xs">
                  {entry.data.links.map(link => (
                    <li>
                      <a href={link.url} class="text-rust-600 dark:text-rust-400 hover:text-rust-700 dark:hover:text-rust-300 underline-offset-2 hover:underline">
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          );
        })}
      </ol>
    </section>
  ))}
</BaseLayout>
