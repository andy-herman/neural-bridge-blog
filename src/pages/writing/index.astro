---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import ResearchCard from '../../components/ResearchCard.astro';
import { readingTime } from '../../lib/reading-time';

const RECENT_PER_SECTION = 3;

const allPosts = (await getCollection('posts', ({ data, id }) => !data.draft && !id.startsWith('ko/')))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = allPosts.slice(0, RECENT_PER_SECTION);

const allResearch = (await getCollection('research', ({ data, id }) => !data.draft && !id.startsWith('ko/')))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentResearch = allResearch.slice(0, RECENT_PER_SECTION);

const allProjects = (await getCollection('projects', ({ id }) => !id.startsWith('ko/')))
  .sort((a, b) => b.data.started.valueOf() - a.data.started.valueOf());
const recentProjects = allProjects.slice(0, RECENT_PER_SECTION);

function dateLabel(d: Date): string {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' }).toUpperCase();
}

const STATUS_LABEL: Record<string, string> = {
  active: 'Active',
  paused: 'Paused',
  archived: 'Archived',
};
---
<BaseLayout title="Writing · neural-bridge.dev" wide>
  <header class="mb-14 pt-4">
    <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-3">// The catalog</p>
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight mb-4" style="font-variation-settings: 'opsz' 96, 'SOFT' 60;">Writing</h1>
    <p class="font-serif italic text-lg text-cream-800 dark:text-cream-200 max-w-2xl">
      Three flavors of work end up here. <strong class="not-italic font-semibold text-cream-900 dark:text-cream-50">Posts</strong> are short, opinionated, build-in-public. <strong class="not-italic font-semibold text-cream-900 dark:text-cream-50">Research</strong> are working papers with citations. <strong class="not-italic font-semibold text-cream-900 dark:text-cream-50">Projects</strong> are the things being built.
    </p>
  </header>

  <!-- Posts section -->
  {recentPosts.length > 0 && (
    <section class="mb-14 border-t border-cream-200 dark:border-cream-900 pt-6">
      <div class="flex items-baseline justify-between mb-2 flex-wrap gap-y-1">
        <div>
          <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-1">// Posts</p>
          <p class="font-serif italic text-sm text-cream-700 dark:text-cream-300">Tight, opinionated, build-in-public. Lessons learned and milestones hit.</p>
        </div>
        <a href="/posts" class="font-mono text-xs uppercase tracking-wider text-cream-800 dark:text-cream-300 hover:text-rust-500 transition-colors shrink-0">All posts ({allPosts.length}) &rarr;</a>
      </div>
      <div class="editorial-list">
        {recentPosts.map((post) => (
          <PostCard
            href={`/posts/${post.slug}`}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            project={post.data.project}
            tags={post.data.tags}
            readingTime={readingTime(post.body)}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Research section -->
  {recentResearch.length > 0 && (
    <section class="mb-14 border-t border-cream-200 dark:border-cream-900 pt-6">
      <div class="flex items-baseline justify-between mb-2 flex-wrap gap-y-1">
        <div>
          <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-1">// Research</p>
          <p class="font-serif italic text-sm text-cream-700 dark:text-cream-300">Working papers on AI security, agentic systems, compliance, and development playbooks. Cited.</p>
        </div>
        <a href="/research" class="font-mono text-xs uppercase tracking-wider text-cream-800 dark:text-cream-300 hover:text-rust-500 transition-colors shrink-0">All research ({allResearch.length}) &rarr;</a>
      </div>
      <div class="editorial-list">
        {recentResearch.map((paper) => (
          <ResearchCard
            href={`/research/${paper.slug}`}
            title={paper.data.title}
            description={paper.data.description}
            pubDate={paper.data.pubDate}
            topic={paper.data.topic}
            status={paper.data.status}
            version={paper.data.version}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Projects section -->
  {recentProjects.length > 0 && (
    <section class="mb-14 border-t border-cream-200 dark:border-cream-900 pt-6">
      <div class="flex items-baseline justify-between mb-2 flex-wrap gap-y-1">
        <div>
          <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-1">// Projects</p>
          <p class="font-serif italic text-sm text-cream-700 dark:text-cream-300">The things being built. Personal AI substrate, the blog you're reading, and what comes next.</p>
        </div>
        <a href="/projects" class="font-mono text-xs uppercase tracking-wider text-cream-800 dark:text-cream-300 hover:text-rust-500 transition-colors shrink-0">All projects ({allProjects.length}) &rarr;</a>
      </div>
      <div class="editorial-list">
        {recentProjects.map((project) => (
          <article class="py-7">
            <a href={`/projects/${project.slug}`} class="block group">
              <div class="flex flex-wrap items-baseline gap-x-3 font-mono text-[11px] tracking-wider uppercase text-cream-800 dark:text-cream-300 mb-2.5">
                <time>{dateLabel(project.data.started)}</time>
                <span class="text-rust-500">/ {STATUS_LABEL[project.data.status] || project.data.status}</span>
              </div>
              <h2 class="font-serif text-2xl sm:text-[1.75rem] font-semibold tracking-tight group-hover:text-rust-500 transition-colors leading-tight mb-3" style="font-variation-settings: 'opsz' 60, 'SOFT' 50;">
                {project.data.title}
              </h2>
              <p class="text-cream-800 dark:text-cream-200 leading-relaxed">{project.data.description}</p>
            </a>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
