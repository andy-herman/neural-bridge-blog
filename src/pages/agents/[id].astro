---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import fs from 'node:fs/promises';
import path from 'node:path';

export async function getStaticPaths() {
  const agents = await getCollection('agents');
  return agents.map(agent => ({
    params: { id: agent.data.id },
    props: { agent },
  }));
}

const { agent } = Astro.props;
const { Content } = await render(agent);

// Color → hex (mirrors index page).
const COLOR_HEX: Record<string, string> = {
  red: '#dc2626',
  orange: '#ea580c',
  yellow: '#ca8a04',
  green: '#16a34a',
  blue: '#2563eb',
  purple: '#9333ea',
  cyan: '#0891b2',
  pink: '#db2777',
  white: '#a8a29e',
  magenta: '#c026d3',
};
const accent = COLOR_HEX[agent.data.color] || '#a8a29e';

// Check if the avatar PNG exists in public/agents/.
const publicAgentsDir = path.resolve('./public/agents');
let hasAvatar = false;
try {
  await fs.access(path.join(publicAgentsDir, `${agent.data.id}.png`));
  hasAvatar = true;
} catch {
  hasAvatar = false;
}
---
<BaseLayout title={`${agent.data.display_name} · neural-bridge.dev`} wide>
  <article class="my-6">
    <!-- Back link -->
    <a href="/agents" class="inline-block mb-6 font-mono text-xs uppercase tracking-wider text-cream-700 dark:text-cream-300 hover:text-rust-500 transition-colors">
      &larr; All agents
    </a>

    <!-- The character card: rounded outer frame with subtle border -->
    <div class="border border-cream-200 dark:border-cream-900 rounded-xl overflow-hidden bg-cream-50 dark:bg-cream-950">
      <!-- Top color stripe -->
      <div class="h-1.5" style={`background-color: ${accent};`} aria-hidden="true"></div>

      <div class="grid grid-cols-1 md:grid-cols-[280px_1fr] gap-0">
        <!-- LEFT: visual column -->
        <aside class="p-6 sm:p-8 border-b md:border-b-0 md:border-r border-cream-200 dark:border-cream-900">
          <p class="font-mono text-[11px] uppercase tracking-wider text-cream-600 dark:text-cream-400 mb-4">
            // System: agent collective
          </p>
          <div class="aspect-square rounded-lg overflow-hidden mb-5 bg-cream-100 dark:bg-cream-900 flex items-center justify-center">
            {hasAvatar ? (
              <img
                src={`/agents/${agent.data.id}.png`}
                alt={`${agent.data.display_name} avatar`}
                width="512"
                height="512"
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="flex flex-col items-center justify-center text-center p-4">
                <p class="font-mono text-[10px] uppercase tracking-wider text-cream-600 dark:text-cream-400 mb-1">// no avatar</p>
                <p class="font-serif text-lg font-semibold text-cream-700 dark:text-cream-300">{agent.data.display_name}</p>
              </div>
            )}
          </div>
          <!-- Color chip + orchestrator badge -->
          <div class="flex items-baseline gap-x-2 mb-4">
            <span class="font-mono text-[11px] uppercase tracking-wider" style={`color: ${accent};`}>
              // {agent.data.color}
            </span>
            {agent.data.is_orchestrator && (
              <span class="font-mono text-[11px] uppercase tracking-wider text-rust-500">· orchestrator</span>
            )}
          </div>
          <!-- Copy-paste Discord mention -->
          <div class="border-t border-cream-200 dark:border-cream-900 pt-4">
            <p class="font-mono text-[10px] uppercase tracking-wider text-cream-600 dark:text-cream-400 mb-1.5">
              // Discord mention
            </p>
            <code class="font-mono text-sm text-rust-600 dark:text-rust-400 select-all">{agent.data.discord_mention}</code>
          </div>
          <div class="border-t border-cream-200 dark:border-cream-900 mt-4 pt-4">
            <p class="font-mono text-[10px] uppercase tracking-wider text-cream-600 dark:text-cream-400 mb-1.5">
              // Model
            </p>
            <code class="font-mono text-xs text-cream-800 dark:text-cream-200">{agent.data.model}</code>
          </div>
        </aside>

        <!-- RIGHT: text column -->
        <div class="p-6 sm:p-8">
          <p class="font-mono text-xs uppercase tracking-wider mb-2" style={`color: ${accent};`}>
            // Character card
          </p>
          <h1
            class="font-serif text-3xl sm:text-4xl font-semibold tracking-tight mb-8 leading-tight"
            style={`color: ${accent}; font-variation-settings: 'opsz' 96, 'SOFT' 60;`}
          >
            {agent.data.display_name}
          </h1>

          <!-- Section 1: Role & Purpose -->
          <section class="mb-8 border-t border-cream-200 dark:border-cream-900 pt-5">
            <div class="flex items-center gap-2.5 mb-3">
              <svg class="w-4 h-4 text-rust-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <h2 class="font-mono text-xs uppercase tracking-wider text-rust-500">Role &amp; Purpose</h2>
            </div>
            <p class="font-serif italic text-base sm:text-lg text-cream-800 dark:text-cream-100 leading-snug mb-3">
              {agent.data.role_tagline}
            </p>
            <div class="prose prose-cream dark:prose-invert prose-sm max-w-none">
              <Content />
            </div>
          </section>

          <!-- Section 2: Operating Principles -->
          {agent.data.operating_principles.length > 0 && (
            <section class="mb-8 border-t border-cream-200 dark:border-cream-900 pt-5">
              <div class="flex items-center gap-2.5 mb-3">
                <svg class="w-4 h-4 text-rust-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                <h2 class="font-mono text-xs uppercase tracking-wider text-rust-500">Operating Principles</h2>
              </div>
              <ol class="space-y-2.5 list-none">
                {agent.data.operating_principles.map((principle, i) => (
                  <li class="flex gap-3">
                    <span class="font-mono text-xs text-cream-500 dark:text-cream-600 mt-1 shrink-0">0{i + 1}</span>
                    <span class="text-cream-800 dark:text-cream-100 leading-relaxed">{principle}</span>
                  </li>
                ))}
              </ol>
            </section>
          )}

          <!-- Section 3: Scope & Tools -->
          <section class="border-t border-cream-200 dark:border-cream-900 pt-5">
            <div class="flex items-center gap-2.5 mb-3">
              <svg class="w-4 h-4 text-rust-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <h2 class="font-mono text-xs uppercase tracking-wider text-rust-500">Scope &amp; Tools</h2>
            </div>

            {agent.data.does_not_own && (
              <div class="mb-4">
                <p class="font-mono text-[10px] uppercase tracking-wider text-cream-600 dark:text-cream-400 mb-1">// Does NOT own</p>
                <p class="text-cream-800 dark:text-cream-100 leading-relaxed text-sm">{agent.data.does_not_own}</p>
              </div>
            )}

            {agent.data.tools.length > 0 && (
              <div class="mb-4">
                <p class="font-mono text-[10px] uppercase tracking-wider text-cream-600 dark:text-cream-400 mb-2">// Tools</p>
                <ul class="flex flex-wrap gap-1.5">
                  {agent.data.tools.map(tool => (
                    <li>
                      <span class="inline-block font-mono text-[11px] px-2 py-0.5 rounded border border-cream-300 dark:border-cream-700 text-cream-800 dark:text-cream-200">{tool}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <div class="pt-2">
              <a
                href={agent.data.plugin_file_url}
                target="_blank"
                rel="noopener"
                class="inline-block font-mono text-xs uppercase tracking-wider text-rust-600 dark:text-rust-400 hover:text-rust-700 dark:hover:text-rust-300 underline underline-offset-4 decoration-1"
              >
                View canonical charter on GitHub &rarr;
              </a>
            </div>
          </section>
        </div>
      </div>
    </div>

    <p class="mt-8 font-serif italic text-sm text-cream-700 dark:text-cream-300 text-center">
      The canonical source for this agent's charter lives in the plugin file. This page is a public-facing summary.
    </p>
  </article>
</BaseLayout>
