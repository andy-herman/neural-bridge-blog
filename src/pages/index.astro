---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import ResearchCard from '../components/ResearchCard.astro';
import Subscribe from '../components/Subscribe.astro';
import Divider from '../components/Divider.astro';
import { readingTime } from '../lib/reading-time';

// Buildlog — 3 most recent, lightweight inline row per entry.
const buildlog = (await getCollection('buildlog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Kind → text-color class. Mirrors the /buildlog page so identity stays
// consistent: milestone/post are the signature rust tones; everything else
// is muted cream.
const KIND_COLOR: Record<string, string> = {
  milestone: 'text-rust-500',
  post: 'text-rust-600',
  release: 'text-cream-700 dark:text-cream-300',
  feature: 'text-cream-700 dark:text-cream-300',
  hardening: 'text-cream-600 dark:text-cream-400',
  fix: 'text-cream-600 dark:text-cream-400',
  note: 'text-cream-500 dark:text-cream-500',
};

function dayLabel(d: Date): string {
  return d.toLocaleString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
}

// Posts — 3 most recent, full PostCard treatment.
const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = allPosts.slice(0, 3);

// Research — 3 most recent, full ResearchCard treatment.
const allResearch = (await getCollection('research', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentResearch = allResearch.slice(0, 3);
---
<BaseLayout title="neural-bridge.dev">
  <section class="mb-14 pt-4">
    <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-5">// Build journal</p>
    <h1 class="font-serif text-5xl sm:text-6xl font-semibold tracking-tight leading-[0.95] mb-6" style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;">
      Building <em class="italic text-rust-500" style="font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;">in&nbsp;public.</em>
    </h1>
    <p class="text-lg sm:text-xl text-cream-800 dark:text-cream-200 leading-relaxed max-w-xl">
      Notes, decisions, and code from <a href="/projects/neural-bridge" class="text-rust-500 underline underline-offset-4 decoration-1 hover:decoration-2">Neural Bridge</a> and the other things I'm building. Cross-posted to LinkedIn where they fit.
    </p>
  </section>

  {buildlog.length > 0 && (
    <section class="mb-12 border-t border-cream-200 dark:border-cream-900 pt-6">
      <div class="flex items-baseline justify-between mb-4">
        <p class="font-mono text-xs text-rust-500 uppercase tracking-wider">// Latest from the build log</p>
        <a href="/buildlog" class="font-mono text-xs uppercase tracking-wider text-cream-800 dark:text-cream-300 hover:text-rust-500 transition-colors">All entries &rarr;</a>
      </div>
      <ol class="space-y-3">
        {buildlog.map(entry => {
          const kindColor = KIND_COLOR[entry.data.kind] || 'text-rust-500';
          return (
            <li>
              <a href="/buildlog" class="flex flex-wrap items-baseline gap-x-3 gap-y-1 group">
                <span class={`font-mono text-xs uppercase tracking-wider ${kindColor}`}>// {entry.data.kind}</span>
                <time class="font-mono text-xs text-cream-700 dark:text-cream-400" datetime={entry.data.date.toISOString()}>{dayLabel(entry.data.date)}</time>
                <span class="font-serif text-base text-cream-900 dark:text-cream-100 group-hover:text-rust-500 transition-colors">{entry.data.title}</span>
              </a>
            </li>
          );
        })}
      </ol>
    </section>
  )}

  {recentPosts.length > 0 && (
    <section class="mb-12 border-t border-cream-200 dark:border-cream-900 pt-6">
      <div class="flex items-baseline justify-between mb-2">
        <p class="font-mono text-xs text-rust-500 uppercase tracking-wider">// Recent posts</p>
        <a href="/posts" class="font-mono text-xs uppercase tracking-wider text-cream-800 dark:text-cream-300 hover:text-rust-500 transition-colors">All posts &rarr;</a>
      </div>
      <div class="editorial-list">
        {recentPosts.map((post) => (
          <PostCard
            href={`/posts/${post.slug}`}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            project={post.data.project}
            tags={post.data.tags}
            readingTime={readingTime(post.body)}
          />
        ))}
      </div>
    </section>
  )}

  {recentResearch.length > 0 && (
    <section class="mb-12 border-t border-cream-200 dark:border-cream-900 pt-6">
      <div class="flex items-baseline justify-between mb-2">
        <p class="font-mono text-xs text-rust-500 uppercase tracking-wider">// Recent research</p>
        <a href="/research" class="font-mono text-xs uppercase tracking-wider text-cream-800 dark:text-cream-300 hover:text-rust-500 transition-colors">All research &rarr;</a>
      </div>
      <div class="editorial-list">
        {recentResearch.map((paper) => (
          <ResearchCard
            href={`/research/${paper.slug}`}
            title={paper.data.title}
            description={paper.data.description}
            pubDate={paper.data.pubDate}
            topic={paper.data.topic}
            status={paper.data.status}
            version={paper.data.version}
          />
        ))}
      </div>
    </section>
  )}

  <Divider />

  <Subscribe />

  <section>
    <p class="font-serif italic text-cream-800 dark:text-cream-200 leading-relaxed">
      Building tools mostly for myself. Sometimes I write about it.
    </p>
  </section>
</BaseLayout>
