---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';
import Subscribe from '../components/Subscribe.astro';
import Divider from '../components/Divider.astro';

// --------- Recent articles: unified feed across posts + research + projects ----------

type ArticleType = 'post' | 'research' | 'project';

interface UnifiedItem {
  type: ArticleType;
  href: string;
  title: string;
  description: string;
  date: Date;
}

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .map<UnifiedItem>(p => ({
    type: 'post',
    href: `/posts/${p.slug}`,
    title: p.data.title,
    description: p.data.description,
    date: p.data.pubDate,
  }));

const research = (await getCollection('research', ({ data }) => !data.draft))
  .map<UnifiedItem>(p => ({
    type: 'research',
    href: `/research/${p.slug}`,
    title: p.data.title,
    description: p.data.description,
    date: p.data.pubDate,
  }));

const projects = (await getCollection('projects'))
  .map<UnifiedItem>(p => ({
    type: 'project',
    href: `/projects/${p.slug}`,
    title: p.data.title,
    description: p.data.description,
    date: p.data.started,
  }));

const allArticles: UnifiedItem[] = [...posts, ...research, ...projects]
  .sort((a, b) => b.date.valueOf() - a.date.valueOf())
  .slice(0, 12);

const TYPE_LABEL: Record<ArticleType, string> = {
  post: 'post',
  research: 'research',
  project: 'project',
};

function dateLabel(d: Date): string {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' }).toUpperCase();
}
---
<BaseLayout title="neural-bridge.dev" wide>
  <section class="mb-14 pt-4">
    <p class="font-mono text-xs text-rust-500 uppercase tracking-wider mb-5">// Build journal</p>
    <h1 class="font-serif text-5xl sm:text-6xl font-semibold tracking-tight leading-[0.95] mb-6" style="font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;">
      Building <em class="italic text-rust-500" style="font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;">in&nbsp;public.</em>
    </h1>
    <p class="text-lg sm:text-xl text-cream-800 dark:text-cream-200 leading-relaxed max-w-xl">
      Notes, decisions, and code from <a href="/projects/neural-bridge" class="text-rust-500 underline underline-offset-4 decoration-1 hover:decoration-2">Neural Bridge</a> and the other things I'm building. Cross-posted to LinkedIn where they fit.
    </p>
  </section>

  {allArticles.length > 0 && (
    <section class="mb-14 border-t border-cream-200 dark:border-cream-900 pt-6">
      <div class="flex items-baseline justify-between mb-5 flex-wrap gap-y-1">
        <p class="font-mono text-xs text-rust-500 uppercase tracking-wider">// Recent articles</p>
        <p class="font-mono text-xs uppercase tracking-wider text-cream-700 dark:text-cream-400">
          <a href="/posts" class="hover:text-rust-500 transition-colors">Posts</a>
          <span class="text-cream-500 dark:text-cream-600"> · </span>
          <a href="/research" class="hover:text-rust-500 transition-colors">Research</a>
          <span class="text-cream-500 dark:text-cream-600"> · </span>
          <a href="/projects" class="hover:text-rust-500 transition-colors">Projects</a>
        </p>
      </div>
      <div class="editorial-list">
        {allArticles.map(item => (
          <article class="py-6">
            <a href={item.href} class="block group">
              <div class="flex flex-wrap items-baseline gap-x-3 font-mono text-[11px] tracking-wider uppercase mb-2.5">
                <span class="text-rust-500">// {TYPE_LABEL[item.type]}</span>
                <time class="text-cream-700 dark:text-cream-400">{dateLabel(item.date)}</time>
              </div>
              <h2 class="font-serif text-xl sm:text-2xl font-semibold tracking-tight group-hover:text-rust-500 transition-colors leading-tight mb-2" style="font-variation-settings: 'opsz' 60, 'SOFT' 50;">
                {item.title}
              </h2>
              <p class="text-cream-800 dark:text-cream-200 leading-relaxed">{item.description}</p>
            </a>
          </article>
        ))}
      </div>
    </section>
  )}

  <Divider />

  <Subscribe />

  <section>
    <p class="font-serif italic text-cream-800 dark:text-cream-200 leading-relaxed">
      Building tools mostly for myself. Sometimes I write about it.
    </p>
  </section>
</BaseLayout>
